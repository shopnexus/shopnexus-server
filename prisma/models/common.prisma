enum ResourceRefType {
  ProductSpu
  ProductSku
  Brand
  Refund
  ReturnDispute
  Comment

  @@map("resource_ref_type")
  @@schema("common")
}

// TODO: should catch "remove" event and remove them in s3;
model Resource {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uploaded_by String? @db.Uuid

  provider   String // From ServiceOption
  object_key String @db.VarChar(2048) // e.g. S3 object key, Cloudinary public_id, or local file path
  mime       String @db.VarChar(100) // MIME type of the resource, e.g. image/jpeg, image/png, etc.
  size       BigInt
  metadata   Json   @db.JsonB

  checksum   String?
  status     Status   @default(Pending)
  created_at DateTime @default(now()) @db.Timestamptz(3)

  author  Account?            @relation("resource_upload_by", fields: [uploaded_by], references: [id], onUpdate: Cascade, onDelete: SetNull)
  profile Profile?            @relation("profile_avatar")
  refs    ResourceReference[]

  @@unique([provider, object_key])
  @@map("resource")
  @@schema("common")
}

model ResourceReference {
  id       BigInt          @id @default(autoincrement())
  rs_id    String          @db.Uuid
  ref_type ResourceRefType
  ref_id   String          @db.Uuid
  order    Int

  resource Resource @relation(fields: [rs_id], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("resource_reference")
  @@schema("common")
}

model ServiceOption {
  id          String  @id @db.VarChar(100) // e.g. "ghn-standard", "vnpay-qr"
  category    String // For listing, e.g. "shipment", "payment", etc.
  name        String // e.g. "Giao hàng nhanh - Standard", "VNPay - QR"
  description String
  provider    String // "ghn", "vnpay", "momo"
  method      String // "standard", "qr", "bank"
  is_active   Boolean @default(true)
  order       Int

  shipments Shipment[]
  payments  Payment[]

  @@index([category, provider])
  @@map("service_option")
  @@schema("common")
}

enum Status {
  Pending
  Processing
  Success
  Canceled
  Failed

  @@map("status")
  @@schema("common")
}
