model OutboxEvent {
  id             BigInt    @id @default(autoincrement())
  topic          String    @db.VarChar(100) // e.g. order.created, product.updated, etc.
  data           Json      @db.JsonB // Event data payload
  processed      Boolean   @default(false) // Whether the event has been processed
  date_processed DateTime? @db.Timestamptz(3)
  date_created   DateTime  @default(now()) @db.Timestamptz(3)

  @@index([date_created])
  @@map("outbox_event")
  @@schema("system")
}
